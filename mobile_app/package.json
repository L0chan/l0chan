{
  "name": "compare2save-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Offline Android and iOS app shell for COMPARE2SAVE.",
  "scripts": {
    "serve": "npx http-server www -p 5173 -c-1",
    "cap:init": "npx cap init \"COMPARE2SAVE\" com.compare2save.app --web-dir www",
    "android:add": "npx cap add android",
    "ios:add": "npx cap add ios",
    "sync": "npx cap sync",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "http-server": "^14.1.1"
  }
}
